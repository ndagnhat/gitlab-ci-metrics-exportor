# HTTP server
HOST=0.0.0.0
PORT=9252

# Endpoints
METRICS_PATH=/metrics
WEBHOOK_PATH=/webhook

# Shared secret configured on the GitLab webhook (X-Gitlab-Token header).
# Leave empty to disable token validation (NOT recommended).
GITLAB_WEBHOOK_SECRET=change-me

# Max webhook body size
BODY_LIMIT=5mb

# Custom HTTP headers configured on the GitLab webhook, used to label
# pipeline metrics with which team/service owns the project.
NAMESPACE_HEADER=X-Namespace
SERVICE_HEADER=X-Service

# Logging: error | warn | info | debug
LOG_LEVEL=info

# Expose default Node.js process metrics alongside the GitLab metrics
DEFAULT_METRICS=true
