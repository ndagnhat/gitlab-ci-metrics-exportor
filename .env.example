# HTTP server
HOST=0.0.0.0
PORT=9252

# Path used for both scraping (GET) and pushing metrics (POST)
METRICS_PATH=/metrics

# Bearer token required on pushes (Authorization: Bearer <token>).
# Leave empty to disable push authentication (NOT recommended).
PUSH_AUTH_TOKEN=change-me

# Max request body size
BODY_LIMIT=1mb

# Logging: error | warn | info | debug
LOG_LEVEL=info

# Expose default Node.js process metrics alongside pushed metrics
DEFAULT_METRICS=true
