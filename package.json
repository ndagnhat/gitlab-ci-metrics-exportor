{
  "name": "gitlab-ci-metrics-exporter",
  "version": "2.0.0",
  "description": "Generic Prometheus push exporter: clients push gauge/counter/histogram metrics over HTTP and the exporter exposes them at /metrics.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test"
  },
  "keywords": [
    "prometheus",
    "exporter",
    "metrics",
    "push",
    "pushgateway",
    "gauge",
    "counter",
    "histogram"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.19.2",
    "prom-client": "^15.1.3"
  }
}
